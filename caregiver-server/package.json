{
  "name": "reflexion-caregiver-app-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:daily-summary-cron": "tsx watch src/jobs/dailySummaryCron.ts",
    "dev:worker": "tsx watch src/jobs/outboxWorker.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:daily-summary-cron": "node dist/jobs/dailySummaryCron.js",
    "start:worker": "node dist/jobs/outboxWorker.js",
    "db:indexes": "tsx src/jobs/ensureIndexes.ts",
    "reminders:materialize": "tsx src/jobs/reminderScheduler.ts",
    "bootstrap:admin": "tsx src/scripts/bootstrapAdmin.ts",
    "provision:device": "tsx src/scripts/provisionDevice.ts",
    "smoke:deployment": "node dist/scripts/smokeDeployment.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "test:integration": "node --import tsx --test src/v1/integration/**/*.test.ts",
    "test:coverage": "node --experimental-test-coverage --test-coverage-include=src/v1/monitoring/algorithms.ts --test-coverage-include=src/v1/monitoring/features.ts --test-coverage-include=src/v1/platform/crypto.ts --test-coverage-include=src/v1/platform/tokens.ts --test-coverage-lines=90 --test-coverage-functions=90 --import tsx --test src/**/*.test.ts",
    "test:coverage:phase3": "node --experimental-test-coverage --test-coverage-include=src/v1/routes/devices.ts --test-coverage-include=src/v1/routes/identity.ts --test-coverage-include=src/v1/routes/sessions.ts --test-coverage-include=src/v1/platform/auth.ts --test-coverage-include=src/v1/platform/idempotency.ts --test-coverage-include=src/v1/platform/objectStore.ts --test-coverage-include=src/v1/platform/qwen.ts --test-coverage-include=src/v1/workers/outboxWorker.ts --test-coverage-lines=90 --test-coverage-functions=90 --import tsx --test src/**/*.test.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "mongodb": "^6.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.25",
    "@types/node": "^22.10.2",
    "@types/supertest": "^7.2.1",
    "mongodb-memory-server": "^11.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
