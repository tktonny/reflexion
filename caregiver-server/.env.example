# Core runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=3001
MONGODB_URI=mongodb://reflexion:change-me@mongo:27017/ref?replicaSet=rs0
MONGODB_DB=ref
MONGODB_MIN_POOL_SIZE=2
MONGODB_MAX_POOL_SIZE=30

# Generate three independent values with: openssl rand -base64 48
JWT_SECRET=replace-with-at-least-32-random-characters
PAIRING_PEPPER=replace-with-a-different-32-character-secret
CREDENTIAL_ENCRYPTION_KEY=replace-with-a-third-32-character-secret

# Browser clients only. Native Android requests are not governed by CORS.
CORS_ALLOWED_ORIGINS=https://caregiver.example.com
AUTH_RATE_LIMIT_PER_MINUTE=20
API_RATE_LIMIT_PER_MINUTE=300
DATA_REGION=your-data-region

# Temporary old Caregiver-client compatibility. Production defaults to the unified v1 surface only.
ENABLE_LEGACY_API=false
# LEGACY_API_SUNSET=Thu, 31 Dec 2026 23:59:59 GMT

# Qwen is server-side only; it is exchanged for a short-lived per-session ticket.
QWEN_API_KEY=replace-on-server-only
QWEN_BASE=https://dashscope.aliyuncs.com
QWEN_REALTIME_ENDPOINT=wss://dashscope.aliyuncs.com/api-ws/v1/realtime
QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime
QWEN_TOKEN_EXPIRE_SECONDS=900

# Optional S3-compatible evidence storage (AWS S3, MinIO, R2-compatible S3 API, etc.)
OBJECT_STORE_DRIVER=s3
OBJECT_STORE_ENDPOINT=https://s3.example.com
OBJECT_STORE_BUCKET=reflexion-evidence
OBJECT_STORE_ACCESS_KEY=replace-on-server-only
OBJECT_STORE_SECRET_KEY=replace-on-server-only
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_SERVER_SIDE_ENCRYPTION=AES256
# OBJECT_STORE_KMS_KEY_ID=

# Optional OpenAI-compatible embedding provider. Leave EMBEDDING_PROVIDER empty to run scalar-only.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_API_BASE=https://embedding-provider.example.com/v1
EMBEDDING_API_KEY=replace-on-server-only
EMBEDDING_MODEL=your-versioned-embedding-model
# EMBEDDING_DIMENSIONS=1024
EMBEDDING_MODEL_VERSION=2026-07

# Optional web-search tool. Weather uses Open-Meteo and does not require a key.
# BRAVE_SEARCH_API_KEY=

# Optional password-reset delivery
# EMAIL_PROVIDER=postmark
# POSTMARK_SERVER_TOKEN=
# EMAIL_FROM=Reflexion <no-reply@example.com>
# CAREGIVER_APP_URL=https://caregiver.example.com

# Version pins written into every session/feature/score for reproducibility
PROTOCOL_VERSION=mirror-v1
PROMPT_VERSION=mirror-zh-v1
TOOL_POLICY_VERSION=home-safe-v1
FEATURE_SCHEMA_VERSION=home-features-v1
MONITORING_PIPELINE_VERSION=longitudinal-v1
MONITORING_RULE_VERSION=transparent-rules-v1

# One-time bootstrap CLI inputs (prefer CLI flags in production)
# BOOTSTRAP_ADMIN_EMAIL=admin@example.com
# BOOTSTRAP_ADMIN_PASSWORD=
# BOOTSTRAP_ADMIN_NAME=Reflexion Admin
# BOOTSTRAP_TENANT_NAME=Reflexion
# PROVISION_DEVICE_SERIAL=
