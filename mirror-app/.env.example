# Production Mirror configuration. Values prefixed EXPO_PUBLIC_ are compiled into the APK.
# They must contain routing/model identifiers only — never database or provider account keys.

# One API domain shared with the Caregiver app. HTTPS is required for production.
EXPO_PUBLIC_API_BASE=https://reflexion.production.tktonny.top

# Native release transport. `ws` uses the backend's short-lived session ticket and the device's
# native audio bridge. `webrtc` requires the workspace URL below and provides hardware AEC.
EXPO_PUBLIC_CONVERSATION_MODE=ws
EXPO_PUBLIC_QWEN_REALTIME_MODEL=qwen3.5-omni-flash-realtime
EXPO_PUBLIC_QWEN_REALTIME_URL=wss://dashscope.aliyuncs.com/api-ws/v1/realtime

# Optional WebRTC deployment instead of `ws`:
# EXPO_PUBLIC_CONVERSATION_MODE=webrtc
# EXPO_PUBLIC_QWEN_WORKSPACE_ID=your-workspace-id
# EXPO_PUBLIC_QWEN_WEBRTC_REGION=cn-beijing
# EXPO_PUBLIC_QWEN_WEBRTC_URL=https://your-workspace.cn-beijing.maas.aliyuncs.com/api/v1/webrtc/realtime

EXPO_PUBLIC_DEFAULT_LANGUAGE=mandarin
EXPO_PUBLIC_QWEN_CHAT_MODEL=qwen-plus
EXPO_PUBLIC_QWEN_VISION_MODEL=qwen-vl-max
EXPO_PUBLIC_QWEN_TTS_MODEL=qwen-tts
EXPO_PUBLIC_QWEN_ASR_MODEL=qwen3-asr-flash
EXPO_PUBLIC_QWEN_OMNI_MODEL=qwen3-omni-flash

# Per-device factory bootstrap credential. It is not a provider key and is accepted only for pairing.
# For production manufacturing, inject a unique value into each device build/provisioning channel.
# Never share one token across devices.
EXPO_PUBLIC_DEVICE_BOOTSTRAP_TOKEN=replace-with-this-device-bootstrap-token

# Local relay is retained only for web development; Android production should use ws/webrtc.
# EXPO_PUBLIC_RELAY_WS_URL=ws://192.168.1.50:8787
