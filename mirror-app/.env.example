# --- Realtime relay (server/index.mjs) ---
# Qwen Omni Realtime key (DashScope). Either name works; QWEN_API_KEY wins.
QWEN_API_KEY=sk-...
DASHSCOPE_API_KEY=sk-...
# Optional relay overrides
# REFLEXION_RELAY_PORT=8787
# REFLEXION_QWEN_OMNI_REALTIME_MODEL=qwen3-omni-flash-realtime

# --- Expo client ---
# WebSocket base for the relay as seen by the browser/device.
# Web on the same machine can omit this (defaults to ws://<host>:8787).
# EXPO_PUBLIC_RELAY_WS_URL=ws://192.168.1.50:8787

# Conversation version switch: relay (v1, Node 中继) | http (v2, 回合制本地) | ws (v3, 原生直连)
EXPO_PUBLIC_CONVERSATION_MODE=relay
# Local modes (http/ws): SECURE DEFAULT = fetch a short-lived token from /api/qwen-token
# (long-term key stays server-side, used only by the token endpoint below via QWEN_API_KEY).
# For a standalone kiosk/APK with NO reachable backend, opt into the inlined client key (EXTRACTABLE):
# EXPO_PUBLIC_ALLOW_INSECURE_CLIENT_KEY=true
# EXPO_PUBLIC_QWEN_API_KEY=sk-...
# EXPO_PUBLIC_QWEN_BASE=https://dashscope.aliyuncs.com

# --- Production hardening (server-side; default OFF so dev/testing works) ---
# Require a paired device (deviceId+authToken vs MirrorPairingSessions) to mint tokens + save conversations:
# REFLEXION_ENFORCE_DEVICE_AUTH=true
# Require device auth on the relay WS upgrade:
# RELAY_ENFORCE_AUTH=true

# Fallback nurse/patient ObjectIds for saving check-ins WITHOUT pairing (testing).
# Seed a matching NursePatientConfig with `npm run seed` (needs MONGODB_URI).
# EXPO_PUBLIC_DEMO_NURSE_ID=64f0000000000000000000a1
# EXPO_PUBLIC_DEMO_PATIENT_ID=65f0000000000000000000b2

# --- Pairing / persistence API routes (Expo Router +api.ts) ---
# Required for saving check-ins (Conversation) + pairing to the caregiver DB `ref`.
MONGODB_URI=mongodb+srv://...
