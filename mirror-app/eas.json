{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://reflexion.production.tktonny.top",
        "EXPO_PUBLIC_ENABLE_INSTALLER_SETUP": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://reflexion.production.tktonny.top",
        "EXPO_PUBLIC_ENABLE_INSTALLER_SETUP": "true",
        "EXPO_PUBLIC_CONVERSATION_MODE": "http"
      }
    },
    "release-apk": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://reflexion.production.tktonny.top",
        "EXPO_PUBLIC_ENABLE_INSTALLER_SETUP": "true",
        "EXPO_PUBLIC_CONVERSATION_MODE": "ws"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "app-bundle" },
      "env": {
        "EXPO_PUBLIC_API_BASE": "https://reflexion.production.tktonny.top",
        "EXPO_PUBLIC_ENABLE_INSTALLER_SETUP": "false",
        "EXPO_PUBLIC_CONVERSATION_MODE": "ws"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
