{
  "expo": {
    "name": "Reflexion Mirror",
    "slug": "reflexion-mobile-mirror-interface-app",
    "version": "1.0.2",
    "orientation": "portrait",
    "scheme": "reflexionmirror",
    "userInterfaceStyle": "light",
    "androidStatusBar": {
      "backgroundColor": "#FFF9F1",
      "barStyle": "dark-content",
      "translucent": false
    },
    "androidNavigationBar": {
      "backgroundColor": "#FFF9F1",
      "barStyle": "dark-content"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Reflexion uses the camera only for diagnostics or future consented features. Daily voice check-ins do not use it.",
        "NSMicrophoneUsageDescription": "Reflexion uses the microphone for realtime AI conversations."
      }
    },
    "android": {
      "package": "com.reflexion.mirror",
      "versionCode": 4,
      "allowBackup": false,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "INTERNET",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "output": "server"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-camera",
      "expo-audio",
      "onnxruntime-react-native",
      "expo-asset",
      "@config-plugins/react-native-webrtc",
      "./plugins/withKioskAndroid"
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
