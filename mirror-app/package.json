{
  "name": "reflexion-mobile-mirror-interface-app",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build:orch": "esbuild src/orchestration/index.ts --bundle --format=esm --platform=node --outfile=server/generated/orchestration.mjs",
    "relay": "npm run build:orch && node --env-file=.env.server.local server/index.mjs",
    "seed": "node --env-file=.env.server.local server/seed-demo-patient.mjs",
    "smoke:hwcheck": "node server/smoke-hwcheck.mjs",
    "smoke:turn-taking-provider": "esbuild server/smoke-turn-taking-provider.ts --bundle --platform=node --format=esm --packages=external --outfile=server/generated/smoke-turn-taking-provider.mjs && node --env-file=.env.server.local server/generated/smoke-turn-taking-provider.mjs",
    "smoke:vision": "node --env-file=.env.server.local server/smoke-vision.mjs",
    "test:turn-taking": "esbuild server/turn-taking.test.ts --bundle --platform=node --format=esm --sourcemap --outfile=server/generated/turn-taking.test.mjs && node --test --experimental-test-coverage server/generated/turn-taking.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "^15.0.1",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@types/qrcode-generator": "^0.0.16",
    "expo": "~56.0.16",
    "expo-asset": "~56.0.20",
    "expo-audio": "~56.0.12",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.17",
    "expo-crypto": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image-manipulator": "~56.0.22",
    "expo-linking": "~56.0.15",
    "expo-router": "~56.2.15",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "mongodb": "^7.3.0",
    "onnxruntime-react-native": "^1.24.3",
    "qrcode-generator": "^2.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2",
    "react-native-webrtc": "^124.0.8",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "esbuild": "^0.28.1",
    "typescript": "~6.0.3"
  }
}
