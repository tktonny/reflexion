{
  "cli": {
    "version": ">= 20.1.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_CAREGIVER_APP_BACKEND_URL": "https://reflexion.production.tktonny.top"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CAREGIVER_APP_BACKEND_URL": "https://reflexion.production.tktonny.top"
      }
    },
    "release-apk": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_CAREGIVER_APP_BACKEND_URL": "https://reflexion.production.tktonny.top"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_CAREGIVER_APP_BACKEND_URL": "https://reflexion.production.tktonny.top"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
