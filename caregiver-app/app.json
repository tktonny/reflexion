{
  "expo": {
    "name": "Reflexion",
    "slug": "reflexion-app",
    "scheme": "reflexion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tarinpairor.reflexionapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Reflexion uses the camera so you can take a photo for an elderly profile.",
        "NSPhotoLibraryUsageDescription": "Reflexion needs photo access so you can choose a photo for an elderly profile.",
        "NSPhotoLibraryAddUsageDescription": "Reflexion may save a chosen profile photo to your library."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.tarinpairor.reflexionapp"
    },
    "web": {
      "output": "server",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-status-bar",
      "expo-notifications",
      "expo-image-picker",
      "expo-camera"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2acc6cdd-8819-4f29-be1d-85d5b4080b0f"
      }
    }
  }
}
